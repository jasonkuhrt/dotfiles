# Secrets (plain text — never commit; encrypted .age files are OK)
*.secrets.*
!*.secrets.*.age

# macOS
.DS_Store

# Homebrew
Brewfile.lock.json

# Serena
.serena/*
!.serena/
!.serena/project.yml

# Claude transcripts (generated output)
**/.claude/transcripts/

# Claude local settings (machine-specific)
CLAUDE.local.md

# Build/test caches
.cache/

# Claude skills tmp dir (runtime state, never committed)
.clauding/

# flo skill state (machine-local epic context)
.flo/

# Temporary review/exploration clones
tmp/

# Node.js
node_modules/

# Research reference clones
research/refs/

# Generated Graffle code
packages/*/src/graffle/

# Python bytecode (generated runtime cache; never useful to commit)
__pycache__/
*.pyc

# Manual config backups (e.g., user-saved snapshots before risky edits)
*_backup.json

# shan-managed (do not edit)
.codex/skills
# end shan-managed
