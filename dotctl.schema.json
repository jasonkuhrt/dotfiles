{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "dotctl configuration",
  "description": "Configuration for dotctl convention-based dotfile deployment.",
  "type": "object",
  "required": ["age"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference (ignored at runtime)."
    },
    "age": {
      "type": "object",
      "description": "age encryption settings for .age files.",
      "required": ["identity", "recipient"],
      "additionalProperties": false,
      "properties": {
        "identity": {
          "type": "string",
          "description": "Path to the age identity (private key) file. Supports ~ expansion."
        },
        "recipient": {
          "type": "string",
          "description": "age public key (recipient) for encryption."
        }
      }
    }
  }
}
