{
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "cleanupPeriodDays": 999999,
  "includeCoAuthoredBy": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/skill-scripts-bun-only.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/skill-scripts-no-bun-on-sh.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/git-worktree-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/block-direct-playwright-test.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/check-template-dsl.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Skill|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/approve-and-persist-permissions.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/cmux-claude-hook.sh notification",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/cmux-claude-hook.sh stop",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/cmux-claude-hook.sh user-prompt-submit",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/rename-terminal-tab.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/cmux-claude-hook.sh session-start",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/session-start-resume-info.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/compact-name-restore.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/flo_next/scripts/compact-recovery.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/cmux-claude-hook.sh session-end",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/cmux-claude-hook.sh precompact",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/cmux-claude-hook.sh subagent-stop",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {},
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
