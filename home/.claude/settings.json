{
  "statusLine": {
    "type": "command",
    "command": "wt list statusline --format=claude-code"
  },
  "cleanupPeriodDays": 999999,
  "includeCoAuthoredBy": false,
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high",
  "preferredNotifChannel": "ghostty",
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "MultiEdit",
      "Write",
      "Read(~/**)",
      "Read(//tmp/**)",
      "WebFetch",
      "WebSearch",
      "Skill(code-review:*)",
      "Skill(hookify:*)",
      "mcp__claude-in-chrome",
      "mcp__effect-docs",
      "mcp__ref",
      "mcp__Ref",
      "Skill(cc-writing-skills)",
      "Skill(flowlist)",
      "Skill(tmux)",
      "Skill(tips)",
      "Skill(dotfiles_doctor)",
      "Skill(shan)",
      "mcp__linear",
      "Skill(draft)",
      "mcp__figma",
      "mcp__Claude_Preview",
      "mcp__plugin_Notion_notion",
      "mcp__mcp-registry",
      "mcp__Claude_in_Chrome"
    ],
    "deny": [],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/Users/jasonkuhrt"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/skill-scripts-bun-only.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/skill-scripts-no-bun-on-sh.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/git-agent-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/git-worktree-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/block-direct-playwright-test.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/block-direct-tsc.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/check-template-dsl.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/approve-and-persist-permissions.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/rename-terminal-tab.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/scripts/compact-name-restore.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      },
      "autoUpdate": true
    },
    "jasonkuhrt": {
      "source": {
        "source": "directory",
        "path": "/Users/jasonkuhrt/projects/jasonkuhrt/claude-marketplace"
      },
      "autoUpdate": true
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    },
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    }
  },
  "enabledPlugins": {
    "Notion@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "impeccable@impeccable": true,
    "plannotator@plannotator": true,
    "playground@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers-dev@superpowers-marketplace": true,
    "tsgo-lsp@jasonkuhrt": true,
    "worktrunk@worktrunk": true
  }
}
