{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bun ~/.codex/hooks/session_start_load_claude_rules.ts",
            "statusMessage": "Loading .claude rules"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ~/.codex/hooks/loop_stop_continue.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jasonkuhrt/.local/bin/plannotator",
            "timeout": 345600
          }
        ]
      }
    ]
  }
}
