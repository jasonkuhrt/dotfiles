                if test $next_index -le (count $tokens); and not string match -q -- '-*' $tokens[$next_index]
                    set i (math $i + 2)
                else
                    set i (math $i + 1)
                end
                continue
            end
            set i (math $i + 1)
            continue
        end
        if string match -q -- '-*' $token
            set i (math $i + 1)
            continue
        end
        set -a words $token
        set i (math $i + 1)
    end
    printf '%s\n' $words
end

function __sb_depth_is
