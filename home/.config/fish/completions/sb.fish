function __sb_words
    set -l tokens (commandline -opc)
    if test (count $tokens) -eq 0
        return 0
    end
    set -e tokens[1]
    set -l words
    set -l i 1
    while test $i -le (count $tokens)
        set -l token $tokens[$i]
        if string match -q -- '--*' $token
            if __sb_global_flag_takes_value $token
                set -l next_index (math $i + 1)
                if test $next_index -le (count $tokens); and not string match -q -- '-*' $tokens[$next_index]
                    set i (math $i + 2)
                else
                    set i (math $i + 1)
                end
                continue
            end
            set -l command (__sb_exact_command $words)
            if test -n "$command"; and __sb_command_flag_takes_value "$command::$token"
                set -l next_index (math $i + 1)
                if test $next_index -le (count $tokens); and not string match -q -- '-*' $tokens[$next_index]
                    set i (math $i + 2)
                else
                    set i (math $i + 1)
                end
                continue
            end
            set i (math $i + 1)
            continue
        end
        if string match -q -- '-*' $token
            set i (math $i + 1)
            continue
        end
        set -a words $token
        set i (math $i + 1)
    end
    printf '%s\n' $words
end

function __sb_depth_is
    set -l depth $argv[1]
    set -l words (__sb_words)
    test (count $words) -eq $depth
end

function __sb_path_is
    set -l words (__sb_words)
    set -l expected $argv
    for i in (seq (count $expected))
        test $i -le (count $words); or return 1
        test "$words[$i]" = "$expected[$i]"; or return 1
    end
    return 0
end

