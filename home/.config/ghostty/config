#
# Ghostty Config (read by cmux — primary terminal)
#
# Reference:
# https://ghostty.org/docs/config/reference
#

theme = tokyonight

#
# Typography
#

font-family    = "Monaspace Neon"
font-size      = 14

#
# Window
#

macos-titlebar-proxy-icon = hidden

#
# Cursor
#

adjust-cursor-thickness = 9
cursor-style-blink      = false
cursor-opacity          = 0.3


#
# Security
#

clipboard-paste-protection = false
confirm-close-surface      = true

#
# Notifications & Bell
#
# OSC 777 notifications → macOS Notification Center (used by Claude Code hooks)
# Bell features: dock bounce + badge for attention when unfocused
#

bell-features = attention

#
# Terminal session persistence
#
# Every new terminal surface enters through the cmux/zmx bridge.
# Outside cmux it falls back to the normal shell.
#

command = direct:/Users/jasonkuhrt/.local/libexec/cmux/cmux-zmx-enter

#
# Keybindings
#

keybind = ctrl+apostrophe=clear_screen
keybind = shift+enter=text:\n

# Internal cmux action surface.
# These Hyper bindings are private implementation detail bindings used by:
# - Karabiner's sticky Ctrl+0 cmux drive mode
# - Neovim's repo-owned cmux-nav bridge
#
# They are intentionally not the user-facing keymap.
keybind = shift+ctrl+alt+cmd+h=goto_split:left
keybind = shift+ctrl+alt+cmd+j=goto_split:down
keybind = shift+ctrl+alt+cmd+k=goto_split:up
keybind = shift+ctrl+alt+cmd+l=goto_split:right

keybind = shift+ctrl+alt+cmd+u=resize_split:left,3
keybind = shift+ctrl+alt+cmd+i=resize_split:down,3
keybind = shift+ctrl+alt+cmd+o=resize_split:up,3
keybind = shift+ctrl+alt+cmd+p=resize_split:right,3

keybind = shift+ctrl+alt+cmd+n=new_split:left
keybind = shift+ctrl+alt+cmd+m=new_split:down
keybind = shift+ctrl+alt+cmd+comma=new_split:up
keybind = shift+ctrl+alt+cmd+period=new_split:right

keybind = shift+ctrl+alt+cmd+z=toggle_split_zoom
keybind = shift+ctrl+alt+cmd+x=close_surface
