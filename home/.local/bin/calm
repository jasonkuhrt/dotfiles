#!/usr/bin/env bash
set -euo pipefail

# @describe calm — a moment to breathe. Mountains, wisdom, and stillness.

# ── Colors ────────────────────────────────────────────────

D='\033[2m'    # dim
R='\033[0m'    # reset
B='\033[1m'    # bold
C='\033[36m'   # cyan
Y='\033[33m'   # yellow
M='\033[35m'   # magenta
W='\033[37m'   # white
G='\033[32m'   # green

# ── Mountain postcards (shared with nesia) ────────────────

_mountain() {
    local idx="${1:-$(( RANDOM % 10 ))}"
    case $idx in
    0) cat <<'ART'
        /\
       /  \
    __/    \__
   /  \    /  \
  / /\ \  / /\ \
_/ /  \ \/ /  \ \_
~~~~~~~~~~~~~~~~~~
ART
        printf '  %bMount Robson%b 3,954m  %bmaps.apple.com/?ll=53.1147,-119.1553&q=Mount+Robson%b\n' "$B" "$R" "$D" "$R"
        ;;
    1) cat <<'ART'
         /\
        /  \
       / /\ \
      / /  \ \
     / /    \ \
    /_/      \_\
   ~~~~~~~~~~~~~~
ART
        printf '  %bMount Assiniboine%b 3,618m  %bmaps.apple.com/?ll=50.8714,-115.6283&q=Mount+Assiniboine%b\n' "$B" "$R" "$D" "$R"
        ;;
    2) cat <<'ART'
      ____/\____
     /  ___  _  \
    / _/   \/  \_\
   /_/           \_\
  ~~~~~~~~~~~~~~~~~~~
ART
        printf '  %bMount Columbia%b 3,747m  %bmaps.apple.com/?ll=52.1497,-117.4381&q=Mount+Columbia%b\n' "$B" "$R" "$D" "$R"
        ;;
    3) cat <<'ART'
     ┌──┐  ┌──┐
     │  │__│  │
    /│  │  │  │\
   / └──┘  └──┘ \
  /              \
  ~~~~~~~~~~~~~~~~
ART
        printf '  %bCastle Mountain%b 2,766m  %bmaps.apple.com/?ll=51.2642,-115.9225&q=Castle+Mountain%b\n' "$B" "$R" "$D" "$R"
        ;;
    4) cat <<'ART'
       /\
      /  \
     /    \
    / /\   \
   / /  \   \
  /_/    \___\
  ~~~~~~~~~~~~~
ART
        printf '  %bMount Temple%b 3,544m  %bmaps.apple.com/?ll=51.3472,-116.2078&q=Mount+Temple%b\n' "$B" "$R" "$D" "$R"
        ;;
    5) cat <<'ART'
          /|
         / |
        /  |
       /   |
      /    |
     /     |
    /______|
  ~~~~~~~~~~
ART
        printf '  %bMount Rundle%b 2,949m  %bmaps.apple.com/?ll=51.1311,-115.4736&q=Mount+Rundle%b\n' "$B" "$R" "$D" "$R"
        ;;
    6) cat <<'ART'
     /\    /\    /\
    /  \  /  \  /  \
   /    \/    \/    \
  /                  \
 /____________________\
 ~~~~~~~~~~~~~~~~~~~~~~
ART
        printf '  %bThe Three Sisters%b 2,936m  %bmaps.apple.com/?ll=51.0467,-115.3781&q=Three+Sisters%b\n' "$B" "$R" "$D" "$R"
        ;;
    7) cat <<'ART'
        /\
       /  \
      / ◇  \
     / /  \ \
    / / ◇◇ \ \
   /_/______\_\
   ~~~~~~~~~~~~~
ART
        printf '  %bMount Edith Cavell%b 3,363m  %bmaps.apple.com/?ll=52.6828,-117.8617&q=Mount+Edith+Cavell%b\n' "$B" "$R" "$D" "$R"
        ;;
    8) cat <<'ART'
       /\
      / |\
     /  | \
    /   |  \
   /  / | \  \
  /__/  |  \__\
  ~~~~~~~~~~~~~~
ART
        printf '  %bMount Fay%b 3,235m  %bmaps.apple.com/?ll=51.3250,-116.2822&q=Mount+Fay%b\n' "$B" "$R" "$D" "$R"
        ;;
    9) cat <<'ART'
      __/\__
     / /  \ \
    / / ≈≈ \ \
   / /  ≈≈  \ \
  /_/________\_\
  ~~~~~~~~~~~~~~
ART
        printf '  %bMount Athabasca%b 3,491m  %bmaps.apple.com/?ll=52.2028,-117.2264&q=Mount+Athabasca%b\n' "$B" "$R" "$D" "$R"
        ;;
    esac
}

# ── Quotes ────────────────────────────────────────────────
# 5 women / 5 men · 5 European / 5 non-European

_quote() {
    local idx="${1:-$(( RANDOM % 10 ))}"
    case $idx in
    0) # Marcus Aurelius · Rome · 121–180
        printf '  %b"You have power over your mind, not outside events.%b\n' "$Y" "$R"
        printf '  %b Realize this, and you will find strength."%b\n' "$Y" "$R"
        printf '  %b— Marcus Aurelius%b\n' "$D" "$R"
        ;;
    1) # Simone Weil · France · 1909–1943
        printf '  %b"Attention is the rarest and purest form%b\n' "$Y" "$R"
        printf '  %b of generosity."%b\n' "$Y" "$R"
        printf '  %b— Simone Weil%b\n' "$D" "$R"
        ;;
    2) # Thich Nhat Hanh · Vietnam · 1926–2022
        printf '  %b"Feelings come and go like clouds in a windy sky.%b\n' "$Y" "$R"
        printf '  %b Conscious breathing is my anchor."%b\n' "$Y" "$R"
        printf '  %b— Thích Nhất Hạnh%b\n' "$D" "$R"
        ;;
    3) # Marie Curie · Poland · 1867–1934
        printf '  %b"Nothing in life is to be feared,%b\n' "$Y" "$R"
        printf '  %b it is only to be understood."%b\n' "$Y" "$R"
        printf '  %b— Marie Curie%b\n' "$D" "$R"
        ;;
    4) # Rumi · Persia · 1207–1273
        printf '  %b"The wound is the place where%b\n' "$Y" "$R"
        printf '  %b the Light enters you."%b\n' "$Y" "$R"
        printf '  %b— Rumi%b\n' "$D" "$R"
        ;;
    5) # Astrid Lindgren · Sweden · 1907–2002
        printf '  %b"Everything great that ever happened in this world%b\n' "$Y" "$R"
        printf '  %b happened first in somebody'"'"'s imagination."%b\n' "$Y" "$R"
        printf '  %b— Astrid Lindgren%b\n' "$D" "$R"
        ;;
    6) # Mary Oliver · USA · 1935–2019
        printf '  %b"Tell me, what is it you plan to do%b\n' "$Y" "$R"
        printf '  %b with your one wild and precious life?"%b\n' "$Y" "$R"
        printf '  %b— Mary Oliver%b\n' "$D" "$R"
        ;;
    7) # Rainer Maria Rilke · Austria · 1875–1926
        printf '  %b"Let everything happen to you. Beauty and terror.%b\n' "$Y" "$R"
        printf '  %b Just keep going. No feeling is final."%b\n' "$Y" "$R"
        printf '  %b— Rainer Maria Rilke%b\n' "$D" "$R"
        ;;
    8) # Yayoi Kusama · Japan · 1929–
        printf '  %b"Forget yourself. Become one with eternity.%b\n' "$Y" "$R"
        printf '  %b Become part of your environment."%b\n' "$Y" "$R"
        printf '  %b— Yayoi Kusama%b\n' "$D" "$R"
        ;;
    9) # Jorge Luis Borges · Argentina · 1899–1986
        printf '  %b"I have always imagined that Paradise%b\n' "$Y" "$R"
        printf '  %b will be a kind of library."%b\n' "$Y" "$R"
        printf '  %b— Jorge Luis Borges%b\n' "$D" "$R"
        ;;
    esac
}

# ── Moon phase ────────────────────────────────────────────

_moon_phase() {
    # Synodic month ≈ 29.53 days. Known new moon: Jan 6, 2000 00:00 UTC
    local now days_since
    now=$(date +%s)
    days_since=$(( now - 947116800 ))
    # Use awk for floating point, tab-delimited output
    awk -v ds="$days_since" 'BEGIN {
        day = ds / 86400
        p = day - int(day / 29.53) * 29.53
        if (p < 0) p += 29.53
        if      (p < 1.85)  printf "🌑 New Moon"
        else if (p < 5.53)  printf "🌒 Waxing Crescent"
        else if (p < 9.22)  printf "🌓 First Quarter"
        else if (p < 12.91) printf "🌔 Waxing Gibbous"
        else if (p < 16.61) printf "🌕 Full Moon"
        else if (p < 20.30) printf "🌖 Waning Gibbous"
        else if (p < 23.99) printf "🌗 Last Quarter"
        else if (p < 27.68) printf "🌘 Waning Crescent"
        else                printf "🌑 New Moon"
    }'
}

# ── Time in words ─────────────────────────────────────────

_time_of_day() {
    local hour
    hour=$(date +%H)
    hour=$((10#$hour))  # force base-10
    if   (( hour < 6 ));  then echo "early morning"
    elif (( hour < 12 )); then echo "morning"
    elif (( hour < 14 )); then echo "midday"
    elif (( hour < 17 )); then echo "afternoon"
    elif (( hour < 20 )); then echo "evening"
    else echo "night"
    fi
}

_gentle_time() {
    local day_name time_of_day date_str
    day_name=$(date +%A)
    time_of_day=$(_time_of_day)
    date_str=$(date "+%B %-d")
    printf '%s %s · %s' "$day_name" "$time_of_day" "$date_str"
}

# ── Commands ──────────────────────────────────────────────

# @cmd A moment of calm — mountain, wisdom, and stillness
# @meta default-subcommand
moment() {
    local mountain_idx=$(( RANDOM % 10 ))
    local quote_idx=$(( RANDOM % 10 ))

    printf '\n'
    _mountain "$mountain_idx" | sed 's/^/  /'
    printf '\n'
    _quote "$quote_idx"
    printf '\n'
    printf '  %b%s%b\n' "$D" "$(_gentle_time)" "$R"
    printf '  %b%s%b\n' "$D" "$(_moon_phase)" "$R"
    printf '\n'
    printf '  %bTry %b%bcalm breathe%b%b for a guided pause%b\n' "$D" "$R" "$M$B" "$R" "$D" "$R"
    printf '\n'
}

# @cmd Guided box breathing — 4 counts in, hold, out, hold
# @arg cycles=3 Number of breathing cycles (1-10)
breathe() {
    local cycles="${argc_cycles}"
    (( cycles > 0 && cycles <= 10 )) || cycles=3

    local mountain_idx=$(( RANDOM % 10 ))
    printf '\n'
    _mountain "$mountain_idx" | sed 's/^/  /'
    printf '\n'
    printf '  %bBox breathing · %s cycles · 4-4-4-4%b\n' "$D" "$cycles" "$R"
    printf '  %bPress Ctrl+C to stop anytime%b\n\n' "$D" "$R"

    local i phase count
    local phases=("breathe in " "hold       " "breathe out" "hold       ")
    local fills=("▓" "░" "▒" "░")

    for (( i = 1; i <= cycles; i++ )); do
        printf '  %bCycle %s/%s%b\n' "$D" "$i" "$cycles" "$R"
        for phase in 0 1 2 3; do
            for (( count = 1; count <= 4; count++ )); do
                local bar=""
                for (( b = 1; b <= count; b++ )); do bar+="${fills[$phase]}"; done
                for (( b = count + 1; b <= 4; b++ )); do bar+="·"; done
                printf '\r  %b%s%b  %s  %b%s%b' "$M" "${phases[$phase]}" "$R" "$bar" "$D" "${count}" "$R"
                sleep 1
            done
            printf '\n'
        done
        if (( i < cycles )); then
            printf '\n'
        fi
    done

    printf '\n  %b✓ %s cycles complete%b\n\n' "$G" "$cycles" "$R"
}

# @cmd Gentle countdown timer with mountain at the end
# @arg minutes=5 Duration in minutes (1-60)
pause() {
    local mins="${argc_minutes}"
    (( mins > 0 && mins <= 60 )) || mins=5
    local total_secs=$(( mins * 60 ))
    local end_time=$(( $(date +%s) + total_secs ))

    printf '\n'
    printf '  %bPausing for %s minutes...%b\n' "$D" "$mins" "$R"
    printf '  %bPress Ctrl+C to end early%b\n\n' "$D" "$R"

    local remaining bar_width=20
    while true; do
        remaining=$(( end_time - $(date +%s) ))
        (( remaining > 0 )) || break

        local elapsed=$(( total_secs - remaining ))
        local filled=$(( elapsed * bar_width / total_secs ))
        local empty=$(( bar_width - filled ))
        local mins_left=$(( remaining / 60 ))
        local secs_left=$(( remaining % 60 ))

        local bar=""
        for (( b = 0; b < filled; b++ )); do bar+="▓"; done
        for (( b = 0; b < empty; b++ )); do bar+="░"; done

        printf '\r  %b%s%b  %b%d:%02d remaining%b' "$C" "$bar" "$R" "$D" "$mins_left" "$secs_left" "$R"
        sleep 1
    done

    printf '\r  %b%s%b  %b✓ done%b              \n\n' "$G" "$(printf '▓%.0s' $(seq 1 $bar_width))" "$R" "$G" "$R"

    # Reward: mountain + quote
    local mountain_idx=$(( RANDOM % 10 ))
    local quote_idx=$(( RANDOM % 10 ))
    _mountain "$mountain_idx" | sed 's/^/  /'
    printf '\n'
    _quote "$quote_idx"
    printf '\n'
}

eval "$(argc --argc-eval "$0" "$@")"
