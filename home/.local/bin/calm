                        · · · · ·
                     __/ · · · · \__
                    / · · · · · · · \
                   / · · · · · · · · \
                  / · · · · · · · · · \
ART
        printf '%b' "$R$C"
        cat <<'ART'
                 /░░░░░░░░░░░░░░░░░░░░░\
                /░░░░░░░░░░░░░░░░░░░░░░░░\
               /░░░≈≈░░░░≈≈≈░░░░≈≈░░░░░░░░\
              /░░≈≈≈≈≈░░≈≈≈≈≈░░≈≈≈≈≈░░░░░░░░\
             /░≈≈≈≈≈≈≈≈≈≈≈≈≈≈≈≈≈≈≈≈≈≈≈░░░░░░░░\
ART
        printf '%b' "$R$D"
        cat <<'ART'
          __/▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒\__
     ▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓
ART
        printf '%b' "$R$G"
        cat <<'ART'
     ↟↟↟  ↟↟↟↟  ↟↟  Sunwapta Pass  ↟↟  ↟↟↟↟↟  ↟↟↟  ↟↟
