#!/usr/bin/env bash
set -euo pipefail

wrapper_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
real_codex="${CODEX2_REAL_BIN:-$(command -v codex 2>/dev/null || true)}"
sync_bin="${CODEX2_SYNC_BIN:-$wrapper_dir/../libexec/codex/codex-tab-sync}"
code_home="${CODEX2_CODEX_HOME:-${CODEX_HOME:-$HOME/.codex}}"

has_bypass_flag() {
    local arg
    for arg in "$@"; do
        if [[ "$arg" == "--dangerously-bypass-approvals-and-sandbox" ]]; then
            return 0
        fi
    done
    return 1
}

build_exec_args() {
    if has_bypass_flag "$@"; then
        printf '%s\0' "$@"
        return 0
    fi

    printf '%s\0' --dangerously-bypass-approvals-and-sandbox "$@"
}

is_uuid() {
    [[ "${1:-}" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]
}

is_interactive_invocation() {
    case "${1:-}" in
        ""|resume|fork)
            return 0
            ;;
        -h|--help|-V|--version)
            return 1
            ;;
        -*)
            return 0
            ;;
        exec|e|review|login|logout|mcp|mcp-server|app-server|app|completion|sandbox|debug|apply|a|cloud|features|help)
            return 1
            ;;
        *)
            return 0
            ;;
    esac
}

thread_name_exists() {
    local name="$1"
    local session_index="$code_home/session_index.jsonl"

    [ -f "$session_index" ] || return 1
    awk -v target="$name" '
        BEGIN { found = 0 }
        {
            match($0, /"thread_name":"([^"]*)"/, m)
            if (m[1] == target) {
                found = 1
            }
        }
        END { exit found ? 0 : 1 }
    ' "$session_index"
}

start_watcher() {
    local selector_kind="$1"
    local selector_value="$2"
    local launch_epoch="$3"
    local log_offset="$4"

    [ -n "${CMUX_WORKSPACE_ID:-}" ] || return 0
    [ -n "${CMUX_SURFACE_ID:-}" ] || return 0
    [ -x "$sync_bin" ] || return 0

    "$sync_bin" \
        --code-home "$code_home" \
        --cmux-bin "${CC_CMUX_CMUX_BIN:-cmux}" \
        --workspace "$CMUX_WORKSPACE_ID" \
        --surface "$CMUX_SURFACE_ID" \
        --cwd "$PWD" \
        --parent-pid "$$" \
        --launch-epoch "$launch_epoch" \
        --log-offset "$log_offset" \
        --selector-kind "$selector_kind" \
        --selector-value "$selector_value" \
        >/dev/null 2>&1 &
}

resume_selector() {
    local expect_value=0
    local selector_kind="none"
    local selector_value=""
    local arg

    shift || true
    for arg in "$@"; do
        if ((expect_value)); then
            expect_value=0
            continue
        fi

        case "$arg" in
            --last)
                selector_kind="last"
                selector_value=""
                ;;
            --config|--enable|--disable|--image|--model|--local-provider|--profile|--sandbox|--ask-for-approval|--cd|--add-dir)
                expect_value=1
                ;;
            --*=*|-*)
                ;;
            *)
                if is_uuid "$arg"; then
                    selector_kind="id"
                    selector_value="$arg"
                    break
                fi
                if thread_name_exists "$arg"; then
                    selector_kind="thread"
                    selector_value="$arg"
                    break
                fi
                ;;
        esac
    done

    printf '%s\n%s\n' "$selector_kind" "$selector_value"
}

if [[ -z "$real_codex" || ! -x "$real_codex" ]]; then
    printf 'codex2: real Codex binary not found\n' >&2
    exit 1
fi

mapfile -d '' -t exec_args < <(build_exec_args "$@")

if ! is_interactive_invocation "${1:-}"; then
    exec "$real_codex" "${exec_args[@]}"
fi

launch_epoch="$(date +%s)"
log_file="$code_home/log/codex-tui.log"
log_offset="0"
if [ -f "$log_file" ]; then
    log_offset="$(wc -c < "$log_file" | tr -d ' ')"
fi

selector_kind="none"
selector_value=""
if [[ "${1:-}" == "resume" ]]; then
    mapfile -t selector_parts < <(resume_selector "$@")
    selector_kind="${selector_parts[0]:-none}"
    selector_value="${selector_parts[1]:-}"
fi

start_watcher "$selector_kind" "$selector_value" "$launch_epoch" "$log_offset"

exec "$real_codex" "${exec_args[@]}"
