#!/usr/bin/env bash
set -euo pipefail

# @describe nesia — personal capability changelog. Because you'll forget what you set up.

DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/nesia"
LOG_FILE="$DATA_DIR/log"
LAST_SEEN="$DATA_DIR/last-seen"

_ensure_log() {
    [[ -d "$DATA_DIR" ]] || mkdir -p "$DATA_DIR"
    [[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"
}

_touch_seen() {
    _ensure_log
    date +%s > "$LAST_SEEN"
}

_format_entries() {
    # tab-separated: date \t category \t description
    # output: date  [category]  description
    while IFS=$'\t' read -r date category description; do
        printf '  %s  \033[36m[%s]\033[0m  %s\n' "$date" "$category" "$description"
    done
}

# @cmd Show recent capability additions
# @alias l
# @arg count=10 Number of entries to show
# @meta default-subcommand
show() {
    _ensure_log
    _touch_seen
    local total
    total="$(wc -l < "$LOG_FILE" | tr -d ' ')"
    if [[ "$total" -eq 0 ]]; then
        printf 'No entries yet. Run: nesia add <category> <description>\n'
        return 0
    fi
    printf 'Recent capabilities (%s of %s):\n\n' "$(( total < argc_count ? total : argc_count ))" "$total"
    tail -n "$argc_count" "$LOG_FILE" | tail -r | _format_entries
    if [[ "$total" -gt "$argc_count" ]]; then
        printf '\n  … run \033[1mnesia all\033[0m for full history\n'
    fi
}

# @cmd Show all entries
all() {
    _ensure_log
    _touch_seen
    local total
    total="$(wc -l < "$LOG_FILE" | tr -d ' ')"
    if [[ "$total" -eq 0 ]]; then
        printf 'No entries yet. Run: nesia add <category> <description>\n'
        return 0
    fi
    printf 'All capabilities (%s entries):\n\n' "$total"
    tail -r "$LOG_FILE" | _format_entries
}

# @cmd Add a new capability entry
# @arg category! Category tag (e.g. fish, git, neovim, cli)
# @arg description+ What you can now do
add() {
    _ensure_log
    local date
    date="$(date +%Y-%m-%d)"
    printf '%s\t%s\t%s\n' "$date" "$argc_category" "${argc_description[*]}" >> "$LOG_FILE"
    printf 'Added: %s [%s] %s\n' "$date" "$argc_category" "${argc_description[*]}"
}

# @cmd Search entries by keyword
# @alias s
# @arg query! Search term
search() {
    _ensure_log
    _touch_seen
    local matches
    matches="$(grep -i "$argc_query" "$LOG_FILE" || true)"
    if [[ -z "$matches" ]]; then
        printf 'No entries matching "%s"\n' "$argc_query"
        return 0
    fi
    local count
    count="$(printf '%s\n' "$matches" | wc -l | tr -d ' ')"
    printf 'Matching "%s" (%s entries):\n\n' "$argc_query" "$count"
    printf '%s\n' "$matches" | tail -r | _format_entries
}

# @cmd Edit the changelog file directly
edit() {
    _ensure_log
    "${EDITOR:-nvim}" "$LOG_FILE"
}

# @cmd Check if nesia is overdue and print a reminder banner (for shell startup)
nag() {
    _ensure_log

    local total
    total="$(wc -l < "$LOG_FILE" | tr -d ' ')"
    [[ "$total" -gt 0 ]] || return 0

    # No last-seen file means never viewed
    if [[ ! -f "$LAST_SEEN" ]]; then
        _print_banner "$total"
        return 0
    fi

    local last_seen now age days_ago
    last_seen="$(cat "$LAST_SEEN")"
    now="$(date +%s)"
    age=$(( now - last_seen ))
    days_ago=$(( age / 86400 ))

    if [[ "$days_ago" -ge 7 ]]; then
        _print_banner "$total" "$days_ago"
    fi
}

_print_banner() {
    local total="${1}" days="${2:-}"
    local d='\033[2m' r='\033[0m' b='\033[1m'
    local c='\033[36m' y='\033[33m' m='\033[35m' w='\033[37m' g='\033[32m'

    local status_line
    if [[ -n "$days" ]]; then
        status_line="Last checked ${days} days ago"
    else
        status_line="Never checked — take a peek!"
    fi

    local idx=$(( RANDOM % 10 ))
    printf '\n'
    case $idx in
    0) # Mount Robson — highest in the Canadian Rockies
        printf '  %b        /\\%b\n' "$w" "$r"
        printf '  %b       /  \\%b        %b★ %s capabilities logged%b\n' "$w" "$r" "$y" "$total" "$r"
        printf '  %b    __/    \\__%b     %b%s%b\n' "$w" "$r" "$d" "$status_line" "$r"
        printf '  %b   /  \\    /  \\%b\n' "$w" "$r"
        printf '  %b  / /\\ \\  / /\\ \\%b   Run %b%bnesia%b to remember\n' "$w" "$r" "$m" "$b" "$r"
        printf '  %b_/ /  \\ \\/ /  \\ \\_%b\n' "$w" "$r"
        printf '  %b~~~~~~~~~~~~~~~~~~%b  %bMount Robson%b 3,954m\n' "$c" "$r" "$b" "$r"
        printf '  %bmaps.apple.com/?ll=53.1147,-119.1553&q=Mount+Robson%b\n' "$d" "$r"
        ;;
    1) # Mount Assiniboine — Matterhorn of the Rockies
        printf '  %b         /\\%b\n' "$w" "$r"
        printf '  %b        /  \\%b       %b★ %s capabilities logged%b\n' "$w" "$r" "$y" "$total" "$r"
        printf '  %b       / /\\ \\%b      %b%s%b\n' "$w" "$r" "$d" "$status_line" "$r"
        printf '  %b      / /  \\ \\%b\n' "$w" "$r"
        printf '  %b     / /    \\ \\%b    Run %b%bnesia%b to remember\n' "$w" "$r" "$m" "$b" "$r"
        printf '  %b    /_/      \\_\\%b\n' "$w" "$r"
        printf '  %b   ~~~~~~~~~~~~~~%b  %bMount Assiniboine%b 3,618m\n' "$c" "$r" "$b" "$r"
        printf '  %bmaps.apple.com/?ll=50.8714,-115.6283&q=Mount+Assiniboine%b\n' "$d" "$r"
        ;;
    2) # Mount Columbia — highest in Alberta
        printf '  %b      ____/\\____%b\n' "$w" "$r"
        printf '  %b     /  ___  _  \\%b  %b★ %s capabilities logged%b\n' "$w" "$r" "$y" "$total" "$r"
        printf '  %b    / _/   \\/  \\_\\%b %b%s%b\n' "$w" "$r" "$d" "$status_line" "$r"
        printf '  %b   /_/           \\_\\%b\n' "$w" "$r"
        printf '  %b  ~~~~~~~~~~~~~~~~~~~%b Run %b%bnesia%b to remember\n' "$c" "$r" "$m" "$b" "$r"
        printf '  %bMount Columbia%b 3,747m\n' "$b" "$r"
        printf '  %bmaps.apple.com/?ll=52.1497,-117.4381&q=Mount+Columbia%b\n' "$d" "$r"
        ;;
    3) # Castle Mountain — flat-topped castellated ridgeline
        printf '  %b     ┌──┐  ┌──┐%b\n' "$w" "$r"
        printf '  %b     │  │__│  │%b    %b★ %s capabilities logged%b\n' "$w" "$r" "$y" "$total" "$r"
        printf '  %b    /│  │  │  │\\%b   %b%s%b\n' "$w" "$r" "$d" "$status_line" "$r"
        printf '  %b   / └──┘  └──┘ \\%b\n' "$w" "$r"
        printf '  %b  /              \\%b  Run %b%bnesia%b to remember\n' "$w" "$r" "$m" "$b" "$r"
        printf '  %b  ~~~~~~~~~~~~~~~~%b\n' "$c" "$r"
        printf '  %bCastle Mountain%b 2,766m\n' "$b" "$r"
        printf '  %bmaps.apple.com/?ll=51.2642,-115.9225&q=Castle+Mountain%b\n' "$d" "$r"
        ;;
    4) # Mount Temple — pyramidal north face
        printf '  %b       /\\%b\n' "$w" "$r"
        printf '  %b      /  \\%b        %b★ %s capabilities logged%b\n' "$w" "$r" "$y" "$total" "$r"
        printf '  %b     /    \\%b       %b%s%b\n' "$w" "$r" "$d" "$status_line" "$r"
        printf '  %b    / /\\   \\%b\n' "$w" "$r"
        printf '  %b   / /  \\   \\%b     Run %b%bnesia%b to remember\n' "$w" "$r" "$m" "$b" "$r"
        printf '  %b  /_/    \\___\\%b\n' "$w" "$r"
        printf '  %b  ~~~~~~~~~~~~~%b   %bMount Temple%b 3,544m\n' "$c" "$r" "$b" "$r"
        printf '  %bmaps.apple.com/?ll=51.3472,-116.2078&q=Mount+Temple%b\n' "$d" "$r"
        ;;
    5) # Mount Rundle — iconic tilted slab above Banff
        printf '  %b          /|%b\n' "$w" "$r"
        printf '  %b         / |%b      %b★ %s capabilities logged%b\n' "$w" "$r" "$y" "$total" "$r"
        printf '  %b        /  |%b      %b%s%b\n' "$w" "$r" "$d" "$status_line" "$r"
        printf '  %b       /   |%b\n' "$w" "$r"
        printf '  %b      /    |%b      Run %b%bnesia%b to remember\n' "$w" "$r" "$m" "$b" "$r"
        printf '  %b     /     |%b\n' "$w" "$r"
        printf '  %b    /______|%b\n' "$w" "$r"
        printf '  %b  ~~~~~~~~~~%b     %bMount Rundle%b 2,949m\n' "$c" "$r" "$b" "$r"
        printf '  %bmaps.apple.com/?ll=51.1311,-115.4736&q=Mount+Rundle%b\n' "$d" "$r"
        ;;
    6) # The Three Sisters — triple peaks near Canmore
        printf '  %b     /\\    /\\    /\\%b\n' "$w" "$r"
        printf '  %b    /  \\  /  \\  /  \\%b  %b★ %s capabilities logged%b\n' "$w" "$r" "$y" "$total" "$r"
        printf '  %b   /    \\/    \\/    \\%b %b%s%b\n' "$w" "$r" "$d" "$status_line" "$r"
        printf '  %b  /                  \\%b\n' "$w" "$r"
        printf '  %b /____________________\\%b Run %b%bnesia%b to remember\n' "$w" "$r" "$m" "$b" "$r"
        printf '  %b ~~~~~~~~~~~~~~~~~~~~~%b\n' "$c" "$r"
        printf '  %bThe Three Sisters%b 2,936m\n' "$b" "$r"
        printf '  %bmaps.apple.com/?ll=51.0467,-115.3781&q=Three+Sisters%b\n' "$d" "$r"
        ;;
    7) # Mount Edith Cavell — Angel Glacier
        printf '  %b        /\\%b\n' "$w" "$r"
        printf '  %b       /  \\%b       %b★ %s capabilities logged%b\n' "$w" "$r" "$y" "$total" "$r"
        printf '  %b      / %b◇%b  \\%b      %b%s%b\n' "$w" "$c" "$w" "$r" "$d" "$status_line" "$r"
        printf '  %b     / /  \\ \\%b\n' "$w" "$r"
        printf '  %b    / / %b◇◇%b \\ \\%b    Run %b%bnesia%b to remember\n' "$w" "$c" "$w" "$r" "$m" "$b" "$r"
        printf '  %b   /_/______\\_\\%b\n' "$w" "$r"
        printf '  %b   ~~~~~~~~~~~~~%b  %bMount Edith Cavell%b 3,363m\n' "$c" "$r" "$b" "$r"
        printf '  %bmaps.apple.com/?ll=52.6828,-117.8617&q=Mount+Edith+Cavell%b\n' "$d" "$r"
        ;;
    8) # Mount Fay — steep triangular face
        printf '  %b       /\\%b\n' "$w" "$r"
        printf '  %b      / |\\%b       %b★ %s capabilities logged%b\n' "$w" "$r" "$y" "$total" "$r"
        printf '  %b     /  | \\%b      %b%s%b\n' "$w" "$r" "$d" "$status_line" "$r"
        printf '  %b    /   |  \\%b\n' "$w" "$r"
        printf '  %b   /  / | \\  \\%b   Run %b%bnesia%b to remember\n' "$w" "$r" "$m" "$b" "$r"
        printf '  %b  /__/  |  \\__\\%b\n' "$w" "$r"
        printf '  %b  ~~~~~~~~~~~~~~%b  %bMount Fay%b 3,235m\n' "$c" "$r" "$b" "$r"
        printf '  %bmaps.apple.com/?ll=51.3250,-116.2822&q=Mount+Fay%b\n' "$d" "$r"
        ;;
    9) # Mount Athabasca — glaciated dome
        printf '  %b      __/\\__%b\n' "$w" "$r"
        printf '  %b     / /  \\ \\%b    %b★ %s capabilities logged%b\n' "$w" "$r" "$y" "$total" "$r"
        printf '  %b    / / %b≈≈%b \\ \\%b   %b%s%b\n' "$w" "$c" "$w" "$r" "$d" "$status_line" "$r"
        printf '  %b   / /  %b≈≈%b  \\ \\%b\n' "$w" "$c" "$w" "$r"
        printf '  %b  /_/________\\_\\%b Run %b%bnesia%b to remember\n' "$w" "$r" "$m" "$b" "$r"
        printf '  %b  ~~~~~~~~~~~~~~%b\n' "$c" "$r"
        printf '  %bMount Athabasca%b 3,491m\n' "$b" "$r"
        printf '  %bmaps.apple.com/?ll=52.2028,-117.2264&q=Mount+Athabasca%b\n' "$d" "$r"
        ;;
    esac
    printf '\n'
}

eval "$(argc --argc-eval "$0" "$@")"
