#!/usr/bin/env bash
set -euo pipefail

# @describe tips — personal capability changelog. Track what you set up so you don't forget it exists.

DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tips"
LOG_FILE="$DATA_DIR/log"
LAST_SEEN="$DATA_DIR/last-seen"

_ensure_log() {
    [[ -d "$DATA_DIR" ]] || mkdir -p "$DATA_DIR"
    [[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"
}

_touch_seen() {
    _ensure_log
    date +%s > "$LAST_SEEN"
}

_format_entries() {
    # tab-separated: date \t category \t description
    # output: date  [category]  description
    while IFS=$'\t' read -r date category description; do
        printf '  %s  \033[36m[%s]\033[0m  %s\n' "$date" "$category" "$description"
    done
}

# @cmd Show recent capability additions
# @alias l
# @arg count=10 Number of entries to show
# @meta default-subcommand
show() {
    _ensure_log
    _touch_seen
    local total
    total="$(wc -l < "$LOG_FILE" | tr -d ' ')"
    if [[ "$total" -eq 0 ]]; then
        printf 'No entries yet. Run: tips add <category> <description>\n'
        return 0
    fi
    printf 'Recent capabilities (%s of %s):\n\n' "$(( total < argc_count ? total : argc_count ))" "$total"
    tail -n "$argc_count" "$LOG_FILE" | tail -r | _format_entries
    if [[ "$total" -gt "$argc_count" ]]; then
        printf '\n  … run \033[1mtips all\033[0m for full history\n'
    fi
}

# @cmd Show all entries
all() {
    _ensure_log
    _touch_seen
    local total
    total="$(wc -l < "$LOG_FILE" | tr -d ' ')"
    if [[ "$total" -eq 0 ]]; then
        printf 'No entries yet. Run: tips add <category> <description>\n'
        return 0
    fi
    printf 'All capabilities (%s entries):\n\n' "$total"
    tail -r "$LOG_FILE" | _format_entries
}

# @cmd Add a new capability entry
# @arg category! Category tag (e.g. fish, git, neovim, cli)
# @arg description+ What you can now do
add() {
    _ensure_log
    local date
    date="$(date +%Y-%m-%d)"
    printf '%s\t%s\t%s\n' "$date" "$argc_category" "${argc_description[*]}" >> "$LOG_FILE"
    printf 'Added: %s [%s] %s\n' "$date" "$argc_category" "${argc_description[*]}"
}

# @cmd Search entries by keyword
# @alias s
# @arg query! Search term
search() {
    _ensure_log
    _touch_seen
    local matches
    matches="$(grep -i "$argc_query" "$LOG_FILE" || true)"
    if [[ -z "$matches" ]]; then
        printf 'No entries matching "%s"\n' "$argc_query"
        return 0
    fi
    local count
    count="$(printf '%s\n' "$matches" | wc -l | tr -d ' ')"
    printf 'Matching "%s" (%s entries):\n\n' "$argc_query" "$count"
    printf '%s\n' "$matches" | tail -r | _format_entries
}

# @cmd Edit the changelog file directly
edit() {
    _ensure_log
    "${EDITOR:-nvim}" "$LOG_FILE"
}

# @cmd Check if tips is overdue and print a reminder banner (for shell startup)
nag() {
    _ensure_log

    local total
    total="$(wc -l < "$LOG_FILE" | tr -d ' ')"
    [[ "$total" -gt 0 ]] || return 0

    # No last-seen file means never viewed
    if [[ ! -f "$LAST_SEEN" ]]; then
        _print_banner "$total"
        return 0
    fi

    local last_seen now age days_ago
    last_seen="$(cat "$LAST_SEEN")"
    now="$(date +%s)"
    age=$(( now - last_seen ))
    days_ago=$(( age / 86400 ))

    if [[ "$days_ago" -ge 7 ]]; then
        _print_banner "$total" "$days_ago"
    fi
}

_print_banner() {
    local total="${1}" days="${2:-}"
    local cyan='\033[36m' dim='\033[2m' bold='\033[1m' reset='\033[0m'
    local yellow='\033[33m' magenta='\033[35m'

    # Gentle nudge with a little character
    printf '\n'
    printf '  %b   ╭─────────────────────────────────────╮%b\n' "$dim" "$reset"
    printf '  %b┌─┐│%b  %b★%b You have %b%s%b capabilities logged  %b│%b\n' "$dim" "$reset" "$yellow" "$reset" "$bold" "$total" "$reset" "$dim" "$reset"
    printf '  %b│▒││%b' "$dim" "$reset"
    if [[ -n "$days" ]]; then
        printf '  %bLast checked %s days ago%b          %b│%b\n' "$dim" "$days" "$reset" "$dim" "$reset"
    else
        printf '  %bNever checked — take a peek!%b       %b│%b\n' "$dim" "$reset" "$dim" "$reset"
    fi
    printf '  %b│░││%b  Run %b%btips%b to see what you can do   %b│%b\n' "$dim" "$reset" "$magenta" "$bold" "$reset" "$dim" "$reset"
    printf '  %b└─┘╰─────────────────────────────────────╯%b\n' "$dim" "$reset"
    printf '\n'
}

eval "$(argc --argc-eval "$0" "$@")"
