#!/usr/bin/env bash
set -euo pipefail

wrapper_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
claude_root="$(cd -- "${wrapper_dir}/.." && pwd)"
real_claude="${CLAUDE_REAL_BIN:-$HOME/.local/bin/claude}"
shim_dir="${claude_root}/cmux"

tmux_pane_id_from_surface() {
    local surface_id="$1"

    case "${surface_id}" in
        surface:*)
            printf '%%%s\n' "${surface_id#surface:}"
            ;;
        *)
            printf '%%%s\n' "${surface_id}"
            ;;
    esac
}

if [[ ! -x "${real_claude}" ]]; then
    printf 'claude wrapper: real binary not found at %s\n' "${real_claude}" >&2
    exit 1
fi

if [[ -z "${CMUX_WORKSPACE_ID:-}" || -z "${CMUX_SURFACE_ID:-}" ]]; then
    exec "${real_claude}" "$@"
fi

export TMUX="cmux"
export TMUX_PANE="$(tmux_pane_id_from_surface "${CMUX_SURFACE_ID}")"
export CC_CMUX_WORKSPACE_ID="${CMUX_WORKSPACE_ID}"
export CC_CMUX_SURFACE_ID="${CMUX_SURFACE_ID}"
export CLAUDE_CODE_TEAMMATE_COMMAND="${CLAUDE_CODE_TEAMMATE_COMMAND:-${wrapper_dir}/claude}"
export PATH="${shim_dir}:${PATH}"

exec "${real_claude}" "$@"
