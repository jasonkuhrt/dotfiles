#!/bin/bash
# Merge managed serena config keys, preserving any runtime additions.
#
# Convention: DOTCTL_SOURCE points to the managed data file.
# Stdin contains current target content.

set -euo pipefail

MANAGED=$(cat "$DOTCTL_SOURCE")
CURRENT=$(cat)

if [ -z "$CURRENT" ]; then
  echo "$MANAGED"
  exit 0
fi

# Merge: managed values override, extra keys in current are preserved
echo "$CURRENT" | yq eval-all 'select(fileIndex == 0) * select(fileIndex == 1)' - <(echo "$MANAGED")
