{
  // ──────────────────────────────────────────── Theme & UI
  "workbench.colorTheme": "Tokyo Night",
  "workbench.iconTheme": "vscode-seedling-icon-theme",
  "workbench.productIconTheme": "icons-carbon",
  "workbench.fontAliasing": "default",
  "workbench.startupEditor": "welcomePageInEmptyWorkbench",
  "workbench.statusBar.visible": true,
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.untitled.hint": "hidden",
  // Native replacement for old `customizeUI.stylesheet` monkey-patch
  "workbench.editor.editorActionsLocation": "hidden",
  // ── UI chrome minimization (keyboard-driven, reclaim screen real estate)
  "workbench.activityBar.location": "hidden",
  "workbench.layoutControl.enabled": false,
  "window.commandCenter": false,

  // ──────────────────────────────────────────── Editor
  "editor.fontFamily": "Fira Code",
  "editor.fontLigatures": true,
  "editor.fontSize": 15,
  "editor.tabSize": 2,
  "editor.insertSpaces": false,
  "editor.minimap.enabled": false,
  "editor.cursorStyle": "line",
  "editor.cursorBlinking": "solid",
  "editor.smoothScrolling": true,
  "editor.lineNumbers": "on",
  "editor.wordWrap": "off",
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "editor.renderLineHighlight": "none",
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": true,
  "editor.selectionHighlight": false,
  "editor.multiCursorModifier": "alt",
  "editor.lightbulb.enabled": "off",
  "editor.inlayHints.enabled": "off",
  "editor.inlineSuggest.enabled": true,
  // Multi-line edit predictions, render side-by-side, allow code shifting around the cursor
  "editor.inlineSuggest.edits.allowCodeShifting": "always",
  "editor.inlineSuggest.edits.renderSideBySide": "auto",
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.suggest.preview": true,
  "editor.suggest.localityBonus": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": false,
  "editor.formatOnPaste": true,
  "editor.defaultFormatter": "dprint.dprint",
  "editor.codeActionsOnSave": {
    "source.addMissingImports": "explicit",
    "source.fixAll.eslint": "explicit",
  },
  "editor.accessibilitySupport": "off",

  // ── Cmd+click and go-to-def: always navigate, never peek.
  //    Defaults peek when there are multiple candidates (interface + impl,
  //    re-exports). "goto" forces navigation to the best match.
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleTypeDefinitions": "goto",
  "editor.gotoLocation.multipleDeclarations": "goto",
  "editor.gotoLocation.multipleImplementations": "goto",
  "editor.gotoLocation.multipleReferences": "goto",
  "editor.definitionLinkOpensInPeek": false,

  // ──────────────────────────────────────────── Files & search
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.associations": { "*.log": "plaintext" },
  "files.exclude": {
    "**/__pycache__": true,
    "**/.coverage": true,
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.pytest_cache": true,
    "**/.serverless": true,
    "**/.svn": true,
    "**/CVS": true,
  },
  "search.exclude": {
    "**/*.tsbuildinfo": true,
    "**/pnpm-lock.yaml": true,
    "**/prisma/migrations": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/coverage": true,
    "**/node_modules": true,
    "**/*.min.js": true,
    "**/bun.lock": true,
  },
  "search.smartCase": true,
  "search.defaultViewMode": "tree",
  "search.sortOrder": "modified",
  "search.searchEditor.reusePriorSearchConfiguration": true,
  "search.searchEditor.defaultNumberOfContextLines": 2,
  "editor.find.autoFindInSelection": "multiline",
  "editor.find.addExtraSpaceOnTop": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,

  // ──────────────────────────────────────────── Project Manager
  //   sortList "Tags" groups projects by their first tag (alphabetical: fav, personal, ref, work).
  //   Sidebar tree view: adds a PROJECTS panel in the activity bar for one-click switching.
  "projectManager.sortList": "Tags",
  "projectManager.treeview.visibility": true,

  // ──────────────────────────────────────────── Terminal
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.lineHeight": 1.25,
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.defaultProfile.osx": "fish",
  "terminal.integrated.profiles.osx": {
    "zsh": null,
    "bash": { "path": "bash" },
    "tmux": null,
    "pwsh": null,
    "fish": { "path": "fish", "args": ["-l"] },
  },
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.commandsToSkipShell": [
    "workbench.action.navigateLeft",
    "workbench.action.navigateRight",
    "workbench.action.navigateUp",
    "workbench.action.navigateDown",
  ],
  "terminal.external.osxExec": "iTerm.app",

  // ──────────────────────────────────────────── Git / GitHub
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "github.autoPublish": true,

  // GitHub PR extension: keep API usage predictable. The extension spends the
  // account-wide GitHub GraphQL quota; huge PRs can fan out through file,
  // comment, review-thread, and webview polling queries.
  "githubPullRequests.devMode": true,
  "githubPullRequests.webviewRefreshInterval": 600,

  // Disable Copilot/Coding Agent surfaces inside the PR extension. These add
  // background polling paths that are separate from normal Copilot completions.
  "githubPullRequests.experimental.chat": false,
  "githubPullRequests.codingAgent.enabled": false,
  "githubPullRequests.codingAgent.uiIntegration": false,

  // Keep the PR tree local-branch-only. The default broad queries refresh
  // "created by me", "waiting for review", Copilot PRs, and all-open buckets.
  "githubPullRequests.queries": [
    {
      "label": "Local Pull Request Branches",
      "query": "default",
    },
  ],
  "githubIssues.queries": [],
  "githubPullRequests.remotes": ["origin"],
  "githubPullRequests.notifications": "off",
  "githubPullRequests.autoRepositoryDetection": "workspace",

  // Huge-PR review ergonomics: avoid extra reveal/filter/comment expansion work
  // while still keeping the PR file tree layout usable on demand.
  "githubPullRequests.fileListLayout": "tree",
  "githubPullRequests.pullBranch": "never",
  "githubPullRequests.hideViewedFiles": false,
  "githubPullRequests.fileAutoReveal": false,
  "githubPullRequests.commentExpandState": "collapseAll",
  "github-actions.org-features": true,

  // ──────────────────────────────────────────── Languages
  "typescript.format.enable": false,
  "typescript.suggestionActions.enabled": false,
  "typescript.suggest.completeFunctionCalls": false,
  // Disable `import { foo as bar }` aliasing during F2 rename. These entries
  // are a *partial* mitigation, not a complete fix. Stock tsserver is known
  // to still insert aliases in multiple scenarios despite the preference:
  // https://github.com/microsoft/TypeScript/issues/29026 (open since 2018).
  // When rename still aliases, fix the binding by hand — the preference
  // cannot currently enforce zero-alias rename everywhere.
  "typescript.preferences.useAliasesForRenames": false,
  "javascript.preferences.useAliasesForRenames": false,
  "typescript.preferGoToSourceDefinition": true,
  "js/ts.experimental.useTsgo": true,
  "typescript.referencesCodeLens.enabled": true,
  "typescript.referencesCodeLens.showOnAllFunctions": true,
  "typescript.implementationsCodeLens.enabled": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.tsc.autoDetect": "off",
  "typescript.tsserver.maxTsServerMemory": 8192,
  // Inlay hints — volume up. Globally suppressed via editor.inlayHints.enabled,
  // toggled on with `space t h` (or ", e" for diagnostics). When on, show all of these.
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterNames.suppressWhenArgumentMatchesName": true,
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.variableTypes.suppressWhenTypeMatchesName": true,
  "javascript.format.enable": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.inlayHints.parameterNames.enabled": "all",
  "javascript.inlayHints.parameterNames.suppressWhenArgumentMatchesName": true,
  "javascript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.inlayHints.enumMemberValues.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "yaml.schemas": {
    "http://json.schemastore.org/circleciconfig": "/*/**/.circleci/*",
  },
  "vscode-graphql.showExecCodelens": false,
  "emmet.showAbbreviationSuggestions": false,
  "emmet.showExpandedAbbreviation": "never",

  // ──────────────────────────────────────────── Task autodetect (silence noise)
  "npm.autoDetect": "off",
  "gulp.autoDetect": "off",
  "grunt.autoDetect": "off",
  "jake.autoDetect": "off",

  // ──────────────────────────────────────────── Markdown
  // ── Open .md files directly into the preview editor (skip source buffer; Cmd+K V toggles to source)
  "workbench.editorAssociations": {
    "*.md": "vscode.markdown.preview.editor",
  },
  // ── Scroll linking: fully decoupled (editor and preview scroll independently)
  "markdown.preview.scrollEditorWithPreview": false,
  "markdown.preview.scrollPreviewWithEditor": false,
  // ── Preview readability: serif body font, generous size + line-height for sustained reading
  "markdown.preview.fontSize": 17,
  "markdown.preview.lineHeight": 1.7,
  "markdown.preview.fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
  // ── Markdown links open in the preview pane (stay in reading mode)
  "markdown.preview.openMarkdownLinks": "inPreview",
  // ── GitHub-flavored rendering: single newlines → <br>, smart quotes/dashes
  "markdown.preview.breaks": true,
  "markdown.preview.typographer": true,
  // ── Don't draw the editor-cursor marker bar in the preview (read-only mode)
  "markdown.preview.markEditorSelection": false,
  // ── Auto-update inbound links when an .md file is moved/renamed
  "markdown.updateLinksOnFileMove.enabled": "always",
  "markdown.updateLinksOnFileMove.enableForDirectories": true,
  // ── Validate broken file/header links inline
  "markdown.validate.enabled": true,
  "markdown.validate.fragmentLinks.enabled": "warning",
  "markdown.validate.fileLinks.enabled": "warning",
  "markdown.validate.referenceLinks.enabled": "warning",
  // ── Drag-drop & paste files → auto-insert image/link markdown
  "markdown.editor.drop.enabled": "smart",
  "markdown.editor.filePaste.enabled": "smart",
  "markdown.editor.pasteUrlAsFormattedLink.enabled": "smartWithSelection",
  // ── Per-language: prose-friendly editor behavior
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    },
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.renderWhitespace": "all"
  },

  // ──────────────────────────────────────────── Misc
  "zenMode.fullScreen": false,
  "security.workspace.trust.untrustedFiles": "open",
  "redhat.telemetry.enabled": true,
  "debug.javascript.autoAttachFilter": "disabled",
  "chat.mcp.gallery.enabled": true,
  "extensions.ignoreRecommendations": true,
  "update.mode": "start",
  // Already default; explicit for documentation purposes
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.extendedRange": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": true,
  },

  // ──────────────────────────────────────────── GitHub Copilot (experimental tab-complete)
  "github.copilot.editor.enableAutoCompletions": true,
  "github.copilot.nextEditSuggestions.fixes": true,
  // Per-language enable. Default true for all; explicitly opt out of plaintext/markdown
  // commits if you don't want suggestions during prose writing.
  "github.copilot.enable": {
    "*": true,
    "scminput": false
  },
  "remote.SSH.useLocalServer": false,
  "remote.SSH.defaultExtensions": ["gitpod.gitpod-remote-ssh"],
  "remote.SSH.remotePlatform": {
    "Development": "linux",
    "dev": "linux",
  },
  "github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled": true,
  "errorLens.enabled": true,
  "editor.codeLens": false,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "problems.visibility": true,
  "security.promptForLocalFileProtocolHandling": false,

  // ──────────────────────────────────────────── vscode-neovim
  "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
}
